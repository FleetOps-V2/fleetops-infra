# Database Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DB_HOST=postgres
DB_PORT=5432

# Authentication
JWT_SECRET=super_secret_jwt_key_that_should_be_long_enough_for_hs256_algorithm
JWT_EXPIRATION=86400000

# Backend Service URLs (used internally by services)
AUTH_SERVICE_URL=http://auth-service:8080
VEHICLE_SERVICE_URL=http://vehicle-service:8080
MAINTENANCE_SERVICE_URL=http://maintenance-service:8080
REQUEST_SERVICE_URL=http://request-service:8080

# CORS: explicit origins only — never use * in production.
# In AWS, inject via Secrets Manager / Parameter Store:
#   CORS_ALLOWED_ORIGINS=https://fleetops.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

